    "expo": "~55.0.8",
    "expo-module-scripts": "^55.0.2",
    "react": "19.2.0",
    "react-native": "0.83.2"
  },
  "peerDependencies": {
    "expo": ">=51.0.0",
    "react": "*",
    "react-native": "*"
  }
